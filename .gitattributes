# Normalize line endings: store LF in the repo, convert on checkout per-OS.
* text=auto eol=lf

# Shell scripts must stay LF.
*.sh text eol=lf
*.mjs text eol=lf

# Binary assets — never apply EOL conversion.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.exe binary
