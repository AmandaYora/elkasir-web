# ─────────────────────────────────────────────────────────────────────────────
# Elkasir — root environment example. Copy the relevant blocks to:
#   apps/api/.env   (backend; loaded via godotenv)
#   apps/web/.env   (frontend; only VITE_* are exposed to the browser)
# NEVER commit a real .env with secrets. This file is the documented source of truth.
# ─────────────────────────────────────────────────────────────────────────────

# ── App / server (apps/api) ──────────────────────────────────────────────────
API_ENV=development
API_ADDR=:8081
# Web dev origins allowed by CORS (comma-separated). Vite dev server = :8080.
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# Public base URL of the backend (used for payment callbacks/redirects).
PUBLIC_BASE_URL=http://localhost:8081

# ── Database (host-level MySQL 8 — NOT a Docker container by default) ─────────
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=elkasir_db
# Optional full DSN override (go-sql-driver). Leave empty to build from DB_* above.
# DB_DSN=root:@tcp(localhost:3306)/elkasir_db?parseTime=true&loc=UTC&charset=utf8mb4&multiStatements=true
# Optional migrate URL override used by scripts/migrate.mjs (golang-migrate format).
# DB_DSN_URL=mysql://root:@tcp(localhost:3306)/elkasir_db

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret-of-at-least-32-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
JWT_APP_TOKEN_TTL=1h    # ActorApp (external payment API) — no refresh token, re-exchange instead

# ── Payments — QRIS/VA, multi-provider (one active). Empty creds = simulation. ───
# These TRIPAY_*/MIDTRANS_*/PAYMENT_* values are used ONLY once, the first time the app boots
# with an empty `payment_gateway_config` table (one-time env→DB migration, PLAN.md §9.1.7).
# After that, edit credentials from Konsol Platform > Konfigurasi Pembayaran instead — these
# env vars are never read again.
# PAYMENT_PROVIDER: tripay | midtrans | (empty = simulation)
# PAYMENT_ENV: sandbox | production (selects each provider's default base URL)
PAYMENT_PROVIDER=tripay
PAYMENT_ENV=sandbox
# Tripay (active): Bearer API Key + Private Key (signature charge & callback verify).
TRIPAY_API_KEY=
TRIPAY_PRIVATE_KEY=
TRIPAY_MERCHANT_CODE=
TRIPAY_QRIS_METHOD=QRIS
# Midtrans (standby): server-side only needs the Server Key.
MIDTRANS_SERVER_KEY=
# Webhook to register in the active provider's dashboard:
#   <PUBLIC_BASE_URL>/api/v1/webhooks/payment

# Encrypts gateway credentials stored in the DB (AES-256-GCM, PLAN.md §9.1.2) — the ONE payment
# secret that stays in .env permanently. Generate a real random value for production, e.g.:
#   openssl rand -base64 32
CONFIG_ENCRYPTION_KEY=

# ── Object storage (S3-compatible — idcloudhost). Empty = upload disabled. ────
# Objek di-upload public-read & disajikan via URL langsung. ACCESS/SECRET KEY
# adalah RAHASIA: isi hanya di apps/api/.env (gitignored), JANGAN commit.
OBJSTORE_ENDPOINT=is3.cloudhost.id
OBJSTORE_REGION=
OBJSTORE_BUCKET=elcodelabs
OBJSTORE_ACCESS_KEY=
OBJSTORE_SECRET_KEY=
OBJSTORE_USE_SSL=true
OBJSTORE_BASE_PATH=elkasir/upload
# Opsional: override URL publik. Kosong = https://<endpoint>/<bucket>.
OBJSTORE_PUBLIC_BASE_URL=

# ── Email notifikasi (SMTP) — opsional. Kosong = fitur no-op (withdrawal's best-effort
# superadmin notification, PLAN.md §2.10/Phase B4). Isi kredensial NYATA hanya di
# apps/api/.env (gitignored), JANGAN commit.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@elkasir.app
SMTP_FROM_NAME=Elkasir Platform

# ── Frontend (apps/web) — must be VITE_-prefixed to reach the browser ─────────
# Dev (web :8080 talks to API :8081):  http://localhost:8081/api/v1
# Prod one-container (SPA served by Go, same-origin):  /api/v1
VITE_API_BASE_URL=http://localhost:8081/api/v1
