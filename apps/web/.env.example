# Env web (Vite). Salin ke .env. Prefix VITE_ agar terbaca di klien.
# Base URL API backend (Fase 10 — saat web di-wire ke API nyata).
#
# Produksi 1-container (SPA di-embed ke binary Go, same-origin): pakai path relatif.
#   VITE_API_BASE_URL=/api
# Dev (web Vite :8080 terpisah dari API :8081): pakai URL penuh ke /api.
VITE_API_BASE_URL=http://localhost:8081/api
