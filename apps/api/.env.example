# ── Elkasir API — contoh environment (SALIN ke apps/api/.env, JANGAN commit .env) ──

# Server
API_ADDR=:8081
API_ENV=development
# Origin web dev yang diizinkan CORS (pisahkan koma). Web Vite dev = :8080.
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Database (MySQL 8) — config menyusun DSN dari variabel terpisah ini.
# Lokal/Laragon umumnya: user "root", password kosong. MySQL via docker compose: host "mysql".
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=elkasir_db
# (Opsional) Override DSN penuh go-sql-driver — pakai bila password berkarakter khusus
# atau deploy di PaaS. Kosongkan agar dibangun dari DB_* di atas.
# DB_DSN=root:@tcp(localhost:3306)/elkasir_db?parseTime=true&loc=UTC&charset=utf8mb4&multiStatements=true

# JWT — ganti dengan secret acak panjang di produksi.
JWT_SECRET=ganti-dengan-secret-acak-min-32-karakter-untuk-produksi
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Pembayaran — Xendit (sandbox). Diisi pada Fase 9; kosong = jalur QRIS dinonaktifkan.
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=
XENDIT_BASE_URL=https://api.xendit.co
# URL publik backend (untuk callback/redirect Xendit). Saat dev pakai ngrok dsb.
PUBLIC_BASE_URL=http://localhost:8081
