# ── Elkasir API — contoh environment (SALIN ke apps/api/.env, JANGAN commit .env) ──

# Server
API_ADDR=:8081
API_ENV=development
# Origin web dev yang diizinkan CORS (pisahkan koma). Web Vite dev = :8080.
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Database (MySQL 8) — config menyusun DSN dari variabel terpisah ini.
# Lokal/Laragon umumnya: user "root", password kosong. MySQL via docker compose: host "mysql".
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=elkasir_db
# (Opsional) Override DSN penuh go-sql-driver — pakai bila password berkarakter khusus
# atau deploy di PaaS. Kosongkan agar dibangun dari DB_* di atas.
# DB_DSN=root:@tcp(localhost:3306)/elkasir_db?parseTime=true&loc=UTC&charset=utf8mb4&multiStatements=true

# JWT — ganti dengan secret acak panjang di produksi.
JWT_SECRET=ganti-dengan-secret-acak-min-32-karakter-untuk-produksi
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ── Pembayaran QRIS — multi-provider, satu aktif ─────────────────────────────
# PAYMENT_PROVIDER: tripay | midtrans | (kosong = mode simulasi/dev)
# PAYMENT_ENV: sandbox | production (menentukan base URL default tiap provider)
PAYMENT_PROVIDER=tripay
PAYMENT_ENV=sandbox

# Tripay (Closed Payment / QRIS). Bearer pakai API Key; Private Key untuk signature
# charge & verifikasi callback. Kosong = jalur QRIS jatuh ke simulasi.
TRIPAY_API_KEY=
TRIPAY_PRIVATE_KEY=
TRIPAY_MERCHANT_CODE=
TRIPAY_QRIS_METHOD=QRIS
# TRIPAY_BASE_URL=            # opsional override (default: sandbox/api-sandbox vs api)

# Midtrans Core API (QRIS). Hanya Server Key yang dipakai server-side (Basic Auth charge +
# verifikasi signature webhook). Client Key milik Snap.js dan TIDAK diperlukan di sini.
MIDTRANS_SERVER_KEY=
# MIDTRANS_BASE_URL=         # opsional override (default: api.sandbox vs api.midtrans)

# URL publik backend → callback/webhook provider: <PUBLIC_BASE_URL>/api/v1/webhooks/payment
# (daftarkan URL itu di dashboard provider aktif). Saat dev pakai ngrok dsb.
PUBLIC_BASE_URL=http://localhost:8081

# ── Email notifikasi (SMTP) — Phase B4, withdrawal.Create -> notifikasi ke semua User Platform.
# Kosong = fitur no-op (lihat mail.Config.Enabled() di PLAN.md Phase B4). Contoh nilai di bawah
# untuk provider SMTP generik; isi apps/api/.env (gitignored) dengan kredensial nyata — JANGAN
# commit kredensial nyata di file .example ini.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@elkasir.app
SMTP_FROM_NAME=Elkasir Platform
